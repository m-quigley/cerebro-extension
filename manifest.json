{
  "manifest_version": 3,
  "name": "Cerebro",
  "description": "Push notifications from cerebro.zeroknowledge.fr \u2014 fires even when the tab is closed.",
  "version": "0.2.3",
  "permissions": [
    "notifications",
    "storage",
    "cookies"
  ],
  "host_permissions": [
    "https://www.zeroknowledge.fr/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Cerebro",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}